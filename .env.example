# Optional: override where local booking cache files are read from.
# PADEL_BOOKING_DATA_DIR=data

# Optional: adjust WebSocket polling frequency in seconds.
# PADEL_BOOKING_POLL_SECONDS=2

# Required by scripts/fetch_padelmates_bookings.py.
# PADELMATES_CLUB_ID=
# PADELMATES_EMAIL=
# PADELMATES_PASSWORD=

# Optional: controls the date window timezone for PadelMates fetches.
# PADELMATES_TIMEZONE=Europe/London
